# ========================================
# GATE SYSTEM - Environment Configuration
# ========================================
# NEVER commit .env file - use .env.example as template
# All sensitive data must be encrypted

# ========================================
# DATABASE (Supabase PostgreSQL)
# ========================================
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_POOL_SIZE=5

# ========================================
# FIREBASE AUTHENTICATION (Google Sign-In)
# ========================================
# Frontend Keys (PUBLIC - safe to expose)
VITE_FIREBASE_API_KEY=AIzaSyD...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcd1234

# Server-side Firebase (PRIVATE - never expose)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBA...\n-----END PRIVATE KEY-----

# ========================================
# SUPABASE CLIENT (Frontend)
# ========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# API SECURITY
# ========================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-secret-key-min-32-chars-here

# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your-admin-api-key-hex-string

# ========================================
# APPLICATION
# ========================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ========================================
# CORS & SECURITY
# ========================================
ALLOWED_ORIGINS=https://selinova-tech.at,https://www.selinova-tech.at,https://selinova-builder.vercel.app
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GET_REQUESTS=120
RATE_LIMIT_WRITE_REQUESTS=20

# ========================================
# MONITORING (Optional)
# ========================================
SENTRY_DSN=https://xxx@sentry.io/123456
